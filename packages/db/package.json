{
  "name": "@ds/db",
  "private": true,
  "version": "0.0.1",
  "description": "Internal Prisma-powered data package for dream-sicle API development and data-feature testing.",
  "homepage": "https://github.com/djarekg/dream-sicle#readme",
  "bugs": {
    "url": "https://github.com/djarekg/dream-sicle/issues"
  },
  "author": "Dustin Griffith <djarekg@gmail.com>",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "clean": "bunx rimraf node_modules dist",
    "db:clean": "bunx rimraf dev.db prisma/migrations",
    "db:migrate": "bunx prisma migrate dev --name init",
    "db:generate": "bunx prisma generate",
    "db:seed": "bun prisma/seed/seed.ts",
    "db": "bun run db:clean && bun run db:generate && bun run db:migrate && bun run db:seed"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "catalog:",
    "@prisma/client": "catalog:",
    "@prisma/driver-adapter-utils": "catalog:",
    "async-mutex": "^0.5.0",
    "bcryptjs": "~3.0.3",
    "js-base64": "^3.7.8",
    "promise-limit": "^2.7.0",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/bun": "catalog:",
    "dotenv": "catalog:",
    "prisma": "catalog:"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "prisma"
  ]
}
