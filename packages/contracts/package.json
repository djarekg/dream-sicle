{
  "name": "@ds/contracts",
  "version": "0.0.1",
  "description": "Shared API contract types for dream-sicle applications.",
  "homepage": "https://github.com/djarekg/dream-sicle#readme",
  "bugs": {
    "url": "https://github.com/djarekg/dream-sicle/issues"
  },
  "author": "Dustin Griffith <djarekg@gmail.com>",
  "license": "MIT",
  "keywords": [
    "contracts",
    "types",
    "api",
    "dream-sicle"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "happy-dom": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
