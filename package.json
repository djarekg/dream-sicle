{
  "name": "@dream-sicle/workspace",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "clean": "rm node_modules .angular out-tsc dist bun.lock; bun run --filter '*' clean",
    "dev": "bun run --filter demo start",
    "lint": "dprint check",
    "format": "dprint fmt"
  },
  "devDependencies": {
    "dprint": "^0.54.0",
    "typescript": "catalog:"
  },
  "catalog": {
    "@angular/aria": "22.0.0-next.4",
    "@angular/build": "22.0.0-next.4",
    "@angular/cdk": "22.0.0-next.3",
    "@angular/cli": "22.0.0-next.3",
    "@angular/common": "22.0.0-next.6",
    "@angular/compiler": "22.0.0-next.6",
    "@angular/compiler-cli": "22.0.0-next.6",
    "@angular/core": "22.0.0-next.6",
    "@angular/forms": "22.0.0-next.6",
    "@angular/material": "22.0.0-next.3",
    "@angular/platform-browser": "22.0.0-next.6",
    "@angular/platform-server": "22.0.0-next.6",
    "@angular/router": "22.0.0-next.6",
    "@angular/ssr": "22.0.0-next.4",
    "@prisma/adapter-libsql": "7.6.0",
    "@prisma/client": "7.6.0",
    "@prisma/driver-adapter-utils": "7.6.0",
    "@types/bun": "latest",
    "@types/node": "latest",
    "dotenv": "^17.3.1",
    "happy-dom": "~20.8.4",
    "jsdom": "^29.0.1",
    "ng-packagr": "22.0.0-next.1",
    "ngx-cookie-service-ssr": "^21.3.1",
    "prisma": "7.6.0",
    "tslib": "^2.8.1",
    "typescript": "6.0.2",
    "vitest": "latest"
  },
  "overrides": {
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11"
