{
  "name": "@dream-sicle/workspace",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.12"
  },
  "packageManager": "bun@1.3.12",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@angular/aria": "22.0.0-next.6",
      "@angular/build": "22.0.0-next.6",
      "@angular/cdk": "22.0.0-next.6",
      "@angular/cli": "22.0.0-next.6",
      "@angular/common": "22.0.0-next.9",
      "@angular/compiler": "22.0.0-next.9",
      "@angular/compiler-cli": "22.0.0-next.9",
      "@angular/core": "22.0.0-next.9",
      "@angular/forms": "22.0.0-next.9",
      "@angular/material": "22.0.0-next.6",
      "@angular/platform-browser": "22.0.0-next.9",
      "@angular/platform-server": "22.0.0-next.9",
      "@angular/router": "22.0.0-next.9",
      "@angular/ssr": "22.0.0-next.6",
      "@eslint/js": "latest",
      "@eslint/json": "latest",
      "@eslint/markdown": "latest",
      "@prisma/adapter-libsql": "7.7.0",
      "@prisma/client": "7.7.0",
      "@prisma/driver-adapter-utils": "7.7.0",
      "@types/bun": "latest",
      "@types/express": "^5.0.1",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/node": "latest",
      "bcryptjs": "^3.0.3",
      "dotenv": "^17.3.1",
      "eslint": "latest",
      "express": "^5.1.0",
      "globals": "latest",
      "happy-dom": "~20.9.0",
      "jsdom": "^29.0.1",
      "jsonwebtoken": "^9.0.3",
      "ng-packagr": "22.0.0-next.3",
      "ngx-cookie-service-ssr": "^21.3.1",
      "prettier": "latest",
      "prisma": "7.7.0",
      "rxjs": "~7.8.0",
      "tslib": "^2.8.1",
      "typescript": "6.0.2",
      "typescript-eslint": "latest",
      "vitest": "latest"
    }
  },
  "scripts": {
    "clean": "bunx rimraf dist out-tsc .angular node_modules bun.lock; bun run --filter '*' clean",
    "setup": "bun run clean; bun install",
    "dev:demo": "bun run --filter demo start",
    "lint": "dprint check",
    "format": "dprint fmt"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@eslint/json": "catalog:",
    "@eslint/markdown": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "overrides": {
    "@angular/common": "catalog:",
    "@angular/core": "catalog:",
    "@angular/ssr": "catalog:",
    "typescript": "catalog:"
  }
}
