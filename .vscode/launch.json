{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "api: launch",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/api",
      "command": "bun run dev",
      "skipFiles": ["**/<node_internals>/**"],
      "sourceMaps": true,
      "smartStep": true,
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "name": "ng: serve",
      "type": "editor-browser",
      "request": "launch",
      "preLaunchTask": "bun: start",
      "url": "http://localhost:4200/"
    },
    {
      "name": "ng: test",
      "type": "editor-browser",
      "request": "launch",
      "preLaunchTask": "npm: test",
      "url": "http://localhost:9876/debug.html"
    }
  ],
  "compounds": [
    {
      "name": "debug: api + ng",
      "configurations": ["api: launch", "ng: serve"],
      "stopAll": true,
      "presentation": {
        "hidden": false,
        "group": "2",
        "order": 1
      }
    }
  ]
}
